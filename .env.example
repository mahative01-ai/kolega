# Local PostgreSQL
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/mahateams_new_gen?schema=public"

# Neon PostgreSQL
# DATABASE_URL uses the pooled connection for the app.
DATABASE_URL="postgresql://USER:PASSWORD@EP-pooler.REGION.aws.neon.tech/DBNAME?sslmode=require&channel_binding=require"

# DIRECT_URL uses the direct connection for Prisma CLI commands.
DIRECT_URL="postgresql://USER:PASSWORD@EP.REGION.aws.neon.tech/DBNAME?sslmode=require"

NEXT_PUBLIC_APP_URL="http://localhost:3000"
AUTH_SECRET="replace-with-a-long-random-secret"
CRON_SECRET="replace-with-another-long-random-secret"

# SMTP email sender for notifications and forgot password.
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER="smtp-user"
SMTP_PASS="smtp-password"
SMTP_FROM="Mahateams <no-reply@mahateams.local>"
