{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "crons": [
    {
      "path": "/api/cron/attendance-alpha",
      "schedule": "0 5 * * *"
    },
    {
      "path": "/api/cron/reminders?run=morning",
      "schedule": "30 1 * * *"
    },
    {
      "path": "/api/cron/reminders?run=evening",
      "schedule": "30 10 * * *"
    }
  ]
}
